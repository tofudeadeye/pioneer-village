  "scripts": {
    "download-server": "cd artifacts && node download.js",
    "start": "./artifacts/20944/FXServer.exe +exec server.cfg +set onesync on +set svgui_disable 1 +set sv_lan 1 +sv_enforceGameBuild 1491",
    "watch": "lerna run watch --stream --parallel",
    "build": "lerna run build --stream --parallel",
    "build:socket": "lerna run build --stream --parallel --scope=socket",
    "prettier": "lerna run prettier --stream --parallel",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "ui:dev": "yarn preact watch --refresh --src ./src/ui/dev --cwd ./resources/ui/",
    "create-resource": "node ./resource-generator.js"
  },
